{{define "dashboard.tmpl"}}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="dark">
<title>stunt — requests</title>
<style>
  :root{
    --stunt-yellow:#ffd400; --stunt-yellow-dim:#e8c200;
    --ink:#0e0e0e; --bone:#f7f4ec; --bone-2:#efe9da; --alert:#e5322d;
    --mono:'JetBrains Mono','SF Mono',ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;
    --sans:'Inter',ui-sans-serif,system-ui,-apple-system,sans-serif;
    --grid:linear-gradient(to right,rgba(255,255,255,.045) 1px,transparent 1px),
           linear-gradient(to bottom,rgba(255,255,255,.045) 1px,transparent 1px);
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--ink);color:var(--bone);font-family:var(--sans);
       -webkit-font-smoothing:antialiased;min-height:100vh;
       background-image:var(--grid);background-size:28px 28px}
  code,pre,.mono{font-family:var(--mono)}
  a{color:var(--stunt-yellow);text-decoration:none}
  /* header */
  header{border-bottom:2px solid var(--ink);background:var(--bone);color:var(--ink)}
  .hdr{max-width:1100px;margin:0 auto;padding:16px 20px;display:flex;align-items:center;gap:14px}
  .hdr .logo{width:30px;height:30px;flex:0 0 auto}
  .hdr h1{font-size:20px;margin:0;font-weight:800;letter-spacing:-.02em}
  .hdr .tag{font-family:var(--mono);font-size:12px;color:var(--ink);opacity:.6;margin-left:auto}
  .stripe{height:6px;background-image:repeating-linear-gradient(-45deg,var(--ink) 0 12px,var(--stunt-yellow) 12px 24px)}
  /* main */
  main{max-width:1100px;margin:0 auto;padding:22px 20px 60px}
  .stats{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:18px;font-family:var(--mono);font-size:12px}
  .stat{border:1px solid rgba(255,255,255,.14);padding:6px 12px}
  .stat b{color:var(--stunt-yellow);font-size:15px}
  .stat span{opacity:.6;margin-left:6px}
  .hint{font-family:var(--mono);font-size:11px;opacity:.5;margin-bottom:14px}
  /* table */
  .reqs{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:13px}
  .reqs thead th{text-align:left;font-weight:600;opacity:.5;padding:8px 10px;
    border-bottom:1px solid rgba(255,255,255,.16);font-size:11px;text-transform:uppercase;letter-spacing:.06em}
  .reqs td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.07);vertical-align:top}
  .reqs tr:hover td{background:rgba(255,212,0,.06)}
  .c-seq{opacity:.4;width:46px}
  .c-method{font-weight:700;width:64px}
  .c-status{text-align:center;width:56px}
  .c-svc{opacity:.55;width:auto;white-space:nowrap}
  .c-dur{opacity:.55;text-align:right;width:72px;white-space:nowrap}
  .c-path{word-break:break-all}
  .pill{display:inline-block;min-width:38px;border-radius:2px;padding:1px 0;font-size:12px}
  .st-ok{color:var(--bone)} .st-ok::before{content:"●";color:#3fd17b;margin-right:3px}
  .st-redir{color:var(--stunt-yellow-dim)}
  .st-4xx{color:var(--stunt-yellow)} .st-4xx::before{content:"●";margin-right:3px}
  .st-5xx{color:var(--alert)}
  .empty{font-family:var(--mono);font-size:13px;opacity:.5;padding:40px 0;text-align:center}
  /* footer */
  footer{border-top:1px solid rgba(255,255,255,.1);font-family:var(--mono);font-size:11px;opacity:.5}
  .ftr{max-width:1100px;margin:0 auto;padding:12px 20px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
  .m-method-get{color:#7fb4ff} .m-method-post{color:#3fd17b}
  .m-method-put{color:#e8a13f} .m-method-delete{color:var(--alert)} .m-method-patch{color:#c792ea}
</style>
</head>
<body>
<header>
  <div class="hdr">
    <img class="logo" src="data:image/svg+xml;utf8,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2064%2064'%3E%3Cdefs%3E%3Cg%20id='s'%3E%3Crect%20x='20'%20y='12'%20width='30'%20height='10'/%3E%3Crect%20x='20'%20y='12'%20width='10'%20height='20'/%3E%3Crect%20x='20'%20y='22'%20width='24'%20height='10'/%3E%3Crect%20x='34'%20y='22'%20width='10'%20height='20'/%3E%3Crect%20x='14'%20y='32'%20width='30'%20height='10'/%3E%3C/g%3E%3C/defs%3E%3Cuse%20href='%23s'%20transform='translate(5,5)'%20fill='%23ffd400'/%3E%3Cuse%20href='%23s'%20fill='%230e0e0e'/%3E%3C/svg%3E" alt="">
    <h1>stunt</h1>
    <span class="tag">request inspector</span>
  </div>
  <div class="stripe"></div>
</header>

<main>
  {{$n := len .}}
  <div class="stats">
    <div class="stat"><b>{{$n}}</b><span>captured</span></div>
    <div class="stat"><b>localhost</b><span>read-only history</span></div>
  </div>
  <div class="hint">live feed + replay + data browsers arrive in Plan 2/3 · refresh to update</div>

  <table class="reqs">
    <thead><tr>
      <th class="c-seq">#</th><th class="c-method">method</th><th class="c-path">path</th>
      <th class="c-status">status</th><th class="c-svc">service</th><th class="c-dur">dur</th>
    </tr></thead>
    <tbody>
    {{range .}}
      <tr>
        <td class="c-seq">{{.Seq}}</td>
        <td class="c-method m-method-{{lower .Method}}">{{.Method}}</td>
        <td class="c-path">{{.Path}}</td>
        <td class="c-status"><span class="pill {{statusClass .Status}}">{{.Status}}</span></td>
        <td class="c-svc">{{.Service}}</td>
        <td class="c-dur">{{humanDur .DurationUs}}</td>
      </tr>
    {{else}}
      <tr><td colspan="6"><div class="empty">no requests captured yet — send one to a running simulator.</div></td></tr>
    {{end}}
    </tbody>
  </table>
</main>

<footer><div class="ftr">
  <span>stunt — local API simulators · the safe stand-in for the real thing</span>
  <span>redacted headers · bodies capped 64KB</span>
</div></footer>
</body>
</html>{{end}}
